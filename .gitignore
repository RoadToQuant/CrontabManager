# ============================================
# Git Ignore for Script Monitor (Crontab Manager)
# ============================================

# --------------------------------------------
# OS / Editor
# --------------------------------------------
.DS_Store
Thumbs.db
*.swp
*.swo
*~
.vscode/
.idea/
*.sublime-project
*.sublime-workspace

# --------------------------------------------
# Backend - Python
# --------------------------------------------
# Virtual Environment
venv/
env/
ENV/
.venv/

# Python Cache
__pycache__/
*.py[cod]
*$py.class
*.so
.Python

# Distribution / Packaging
build/
dist/
*.egg-info/
.eggs/

# Testing
.pytest_cache/
.coverage
htmlcov/
.tox/
.nox/

# MyPy
.mypy_cache/
.dmypy.json
dmypy.json

# Jupyter Notebook
.ipynb_checkpoints

# Environment Variables
.env
.env.local
.env.*.local
!.env.example

# SQLite Database (optional: 根据需求决定是否忽略)
# 开发环境建议忽略，生产环境备份
*.db
*.sqlite
*.sqlite3

# Logs
*.log
logs/

# --------------------------------------------
# Frontend - Node.js / Next.js
# --------------------------------------------
# Dependencies
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# Next.js Build Output
.next/
out/

# Production Build
build/
dist/

# Cache
.cache/
.eslintcache
.stylelintcache
*.tsbuildinfo

# Vercel
.vercel

# --------------------------------------------
# Project Specific
# --------------------------------------------
# Runtime Data
backend/data/scripts/
backend/data/logs/
backend/data/*.db

# Temporary Files
tmp/
temp/
*.tmp

# Backup Files
*.bak
*.backup

# --------------------------------------------
# Keep These Files (使用 ! 取反)
# --------------------------------------------
# 确保示例配置文件不被忽略
!.env.example
!backend/data/.gitkeep
!backend/data/scripts/.gitkeep
!backend/data/logs/.gitkeep
