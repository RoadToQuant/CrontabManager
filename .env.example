# Script Monitor 配置文件
# Crontab 可视化管理系统

# 后端配置
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000

# 数据库配置
DATABASE_URL=sqlite:///./data/monitor.db

# 数据目录
DATA_DIR=./data
SCRIPTS_DIR=./data/scripts

# Crontab 配置
# 留空表示使用当前用户的 crontab
# 设置为 "root" 需要 root 权限
CRONTAB_USER=

# 任务前缀 (用于在 crontab 中识别 script-monitor 的任务)
CRON_TASK_PREFIX=# script-monitor-task:
