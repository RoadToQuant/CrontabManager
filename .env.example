# Crontab Manager Configuration
# Copy this file to .env and modify as needed

# ============================================
# Backend Configuration
# ============================================

# Host to bind the backend server (0.0.0.0 for all interfaces, 127.0.0.1 for localhost only)
BACKEND_HOST=0.0.0.0

# Port for the backend server
BACKEND_PORT=8000

# Data directory for scripts and logs (relative to backend/ or absolute path)
DATA_DIR=./data
SCRIPTS_DIR=./data/scripts

# Crontab Configuration
# Leave empty to use current user's crontab
# Set to "root" to use system crontab (requires root permissions)
CRONTAB_USER=

# Task prefix in crontab (used to identify script-monitor tasks)
CRON_TASK_PREFIX=# script-monitor-task:

# ============================================
# Frontend Configuration
# ============================================

# Port for the frontend development server
FRONTEND_PORT=3000

# Backend API URL (used by frontend to connect to backend)
# Default: http://localhost:8000
# Change this if backend is running on a different host/port
NEXT_PUBLIC_API_URL=http://localhost:8000

# ============================================
# Advanced Configuration (Optional)
# ============================================

# Log level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# Maximum log file size in MB (for log rotation)
MAX_LOG_SIZE=10

# Number of log files to keep
MAX_LOG_FILES=5
