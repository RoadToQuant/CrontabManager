# ============================================
# Git Attributes
# ============================================

# 自动处理行尾符
* text=auto eol=lf

# 二进制文件
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.pdf binary
*.zip binary
*.gz binary
*.tar binary
*.7z binary

# 脚本文件保持可执行权限
*.sh text eol=lf
*.py text eol=lf
*.js text eol=lf
*.ts text eol=lf
*.tsx text eol=lf

# 语言检测
*.py linguist-language=Python
*.ts linguist-language=TypeScript
*.tsx linguist-language=TSX
